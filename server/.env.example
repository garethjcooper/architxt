# ArchiTXT Backend Configuration
# ====================================
# Copy this file to .env and fill in your own values.
# All entries shown with their defaults.
# ====================================

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
ARCHITXT_PORT=3000
ARCHITXT_HOST=0.0.0.0
ARCHITXT_NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
ARCHITXT_DB_PATH=./database/architxt.db
ARCHITXT_DB_TIMEOUT_MS=10000

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
ARCHITXT_LOG_LEVEL=debug
ARCHITXT_LOG_DIR=./logs

# ─────────────────────────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────────────────────────
ARCHITXT_STORAGE_PATH=./documents
ARCHITXT_TEMP_DIR=./tmp
ARCHITXT_MAX_FILE_SIZE=104857600

# ─────────────────────────────────────────────────────────────
# Docling Document Processing Service
# ─────────────────────────────────────────────────────────────
DOCLING_SERVICE_URL=http://localhost:5001
# Set to true to force OCR on every page. Use this when PDFs contain
# subsetted fonts without ToUnicode CMaps, which cause glyph substitution
# artifacts (/g###/ tokens) in extracted text. Slower but eliminates corruption.
ARCHITXT_DOCLING_FORCE_OCR=false

# ─────────────────────────────────────────────────────────────
# LLM Providers (fill in your API keys)
# ─────────────────────────────────────────────────────────────
ARCHITXT_OLLAMA_LOCAL_URL=http://localhost:11434
ARCHITXT_OLLAMA_LOCAL_API_KEY=ollamaapikey
ARCHITXT_OLLAMA_LOCAL_DEFAULT_MODEL=qwen3.5:4b
ARCHITXT_OLLAMA_LOCAL_TIMEOUT_MS=300000
ARCHITXT_OLLAMA_LOCAL_CHAT_STYLE=ollama_local

ARCHITXT_OLLAMA_CLOUD_URL=https://ollama.com/v1
ARCHITXT_OLLAMA_CLOUD_API_KEY=
ARCHITXT_OLLAMA_CLOUD_DEFAULT_MODEL=kimi-k2.5:cloud
ARCHITXT_OLLAMA_CLOUD_TIMEOUT_MS=300000
ARCHITXT_OLLAMA_CLOUD_CHAT_STYLE=openai

ARCHITXT_OPENAI_URL=https://api.openai.com/v1
ARCHITXT_OPENAI_API_KEY=
ARCHITXT_OPENAI_DEFAULT_MODEL=gpt-4o
ARCHITXT_OPENAI_TIMEOUT_MS=60000
ARCHITXT_OPENAI_CHAT_STYLE=openai

ARCHITXT_ANTHROPIC_URL=https://api.anthropic.com/v1
ARCHITXT_ANTHROPIC_API_KEY=
ARCHITXT_ANTHROPIC_DEFAULT_MODEL=claude-3-sonnet-20240229
ARCHITXT_ANTHROPIC_TIMEOUT_MS=180000
ARCHITXT_ANTHROPIC_CHAT_STYLE=openai

# ─────────────────────────────────────────────────────────────
# Research Discovery Agent
# ─────────────────────────────────────────────────────────────
ARCHITXT_RESEARCH_SHAPER_PROVIDER=ollama_cloud
ARCHITXT_RESEARCH_SHAPER_MODEL=
ARCHITXT_RESEARCH_SHAPER_TEMPERATURE=0.2
ARCHITXT_RESEARCH_SHAPER_MAX_TOKENS=

# ─────────────────────────────────────────────────────────────
# Vision / Diagram Description
# ─────────────────────────────────────────────────────────────
ARCHITXT_VISION_ENABLED=true
ARCHITXT_VISION_PROVIDER=ollama_cloud
ARCHITXT_VISION_MODEL=ministral-3:14b-cloud
ARCHITXT_VISION_TIMEOUT_MS=300000
ARCHITXT_DIAGRAM_TEMPERATURE=0.0
ARCHITXT_DIAGRAM_BATCH_SIZE=2
ARCHITXT_DIAGRAM_MAX_BATCHES=-1
ARCHITXT_DIAGRAM_CONCURRENCY=3

# ─────────────────────────────────────────────────────────────
# Document Denoise (LLM-based)
# ─────────────────────────────────────────────────────────────
ARCHITXT_DENOISE_LLM_ENABLED=true
ARCHITXT_DENOISE_LLM_PROVIDER=ollama_cloud
ARCHITXT_DENOISE_LLM_MODEL=ministral-3:14b-cloud
ARCHITXT_DENOISE_LLM_TIMEOUT_MS=600000
ARCHITXT_DENOISE_LLM_TEMPERATURE=0.1

# ─────────────────────────────────────────────────────────────
# Document Denoise (Basic text cleanup)
# ─────────────────────────────────────────────────────────────
ARCHITXT_DENOISE_ENABLED=true
ARCHITXT_DENOISE_REMOVE_PAGE_NUMBERS=1
ARCHITXT_DENOISE_REMOVE_CONFIDENTIAL=1
ARCHITXT_DENOISE_REMOVE_DOC_IDS=1
ARCHITXT_DENOISE_UNESCAPE_HTML=1
ARCHITXT_DENOISE_NORMALIZE_WS=1
ARCHITXT_DENOISE_REMOVE_NON_ASCII=1
ARCHITXT_DENOISE_MAX_NEWLINES=3

# ─────────────────────────────────────────────────────────────
# Daemon Control
# ─────────────────────────────────────────────────────────────
SPAWN_EXTRACT_DAEMON=true
SPAWN_HINDSIGHT_POLL_DAEMON=true
ARCHITXT_EXTRACT_DAEMON_POLL_INTERVAL_MS=5000
ARCHITXT_EXTRACT_DAEMON_ORPHAN_THRESHOLD_MINUTES=600
ARCHITXT_HINDSIGHT_POLL_INTERVAL_MS=5000
ARCHITXT_HINDSIGHT_STALE_THRESHOLD_MS=300000
