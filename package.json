{
  "name": "architxt",
  "version": "0.2.1",
  "description": "architxt: Document processing pipeline with web UI",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "server",
    "ui"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "build": "node scripts/build.js",
    "start": "node scripts/start.js",
    "dev": "node scripts/dev.js",
    "clean": "node scripts/clean.js",
    "purge": "node scripts/purge.js",
    "lint": "cd server && npm run lint && cd ../ui && npm run lint"
  }
}
